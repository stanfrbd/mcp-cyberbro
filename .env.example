# Required: URL of your Cyberbro instance
CYBERBRO_URL=http://localhost:5000

# Optional: Cyberbro API prefix
API_PREFIX=api

# Optional: SSL verification for Cyberbro backend calls
# true|false
SSL_VERIFY=true

# MCP transport for local runs
# stdio|sse|streamable-http
MCP_TRANSPORT=stdio

# Host and port used with HTTP transports (sse/streamable-http)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Optional SSE settings
MCP_MOUNT_PATH=/
MCP_SSE_PATH=/sse

# Optional Streamable HTTP endpoint path
MCP_STREAMABLE_HTTP_PATH=/mcp
